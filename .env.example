# =====================================================
# TaxFlow 환경 변수 예시
# 실제 값은 .env.local 에 입력하세요. (.env.local 은 커밋 금지)
# =====================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI ---
# 서버 전용. 절대 클라이언트에 노출 금지.
OPENAI_API_KEY=
# 텍스트 생성 모델 (기대 품질에 맞춰 조정)
OPENAI_MODEL=gpt-4o
# 음성 인식(상담 오디오) 모델
OPENAI_TRANSCRIBE_MODEL=whisper-1

# --- App ---
# 로컬: http://localhost:3000 / Production: https://taxflo.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- 결제 (나이스페이 카드 빌링) ---
BILLING_PROVIDER=nicepay
# 서버 전용. 절대 클라이언트에 노출 금지.
NICEPAY_MID=
NICEPAY_MERCHANT_KEY=
# 정기 결제 cron 호출용 (선택)
# BILLING_CRON_SECRET=
